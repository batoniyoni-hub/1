# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your_secret_key_here

# Database
DB_PATH=accounts.db

# Proxy Settings
PROXY_TIMEOUT=10
PROXY_RETRY_ATTEMPTS=3

# API Settings
API_PORT=5000
API_HOST=0.0.0.0
API_WORKERS=4

# Account Creation
DEFAULT_COUNTRY=US
DEFAULT_PLATFORM=facebook
MAX_THREADS=10

# Mail Settings
MAIL_PROVIDER=mail.tm
MAIL_TIMEOUT=15
